# Files that execute on the Raspberry Pis MUST keep LF line endings —
# a CRLF shell script fails on Linux with "bad interpreter" / $'\r' errors.
*.sh      text eol=lf
*.rules   text eol=lf
*.service text eol=lf
*.py      text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf

# Firmware sources are edited in the Arduino IDE on any OS
*.ino     text

# Model weights are binary
*.pt      binary
*.nxs     binary

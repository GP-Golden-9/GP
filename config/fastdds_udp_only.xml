<?xml version="1.0" encoding="UTF-8"?>
<!--
  Force FastDDS onto plain UDPv4 (loopback, since ROS_LOCALHOST_ONLY=1)
  and DISABLE the shared-memory transport.

  Why: SHM on the Pis proved to be a per-boot lottery. Crash debris in
  /dev/shm silently ate every message once (2026-06-11, field report
  B-13), and a day later a boot came up with subscriptions deaf and NO
  segments at all - discovery matched, delivery dead, twice, with two
  different states. UDP loopback costs microseconds and removes the
  whole failure class: no segments, no cleanup, no lottery.

  Loaded via Environment=FASTRTPS_DEFAULT_PROFILES_FILE=... in the
  gp-robot units.
-->
<profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
  <transport_descriptors>
    <transport_descriptor>
      <transport_id>udp_only</transport_id>
      <type>UDPv4</type>
    </transport_descriptor>
  </transport_descriptors>

  <participant profile_name="gp_udp_only" is_default_profile="true">
    <rtps>
      <userTransports>
        <transport_id>udp_only</transport_id>
      </userTransports>
      <useBuiltinTransports>false</useBuiltinTransports>
    </rtps>
  </participant>
</profiles>

[Unit]
Description=GP Robot2 preflight checks (serial name, camera, disk, power, deps)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
User=pi
Environment=GP_DIR=/home/pi/GP
ExecStart=/bin/bash /home/pi/GP/robots/robot2/scripts/preflight.sh

[Install]
WantedBy=multi-user.target
